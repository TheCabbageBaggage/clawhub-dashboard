<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>📰 Newsletter Operations Hub</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            background: #0f1117;
            color: #e0e0e0;
            min-height: 100vh;
            padding: 40px 20px;
        }
        .container { max-width: 1200px; margin: 0 auto; }
        
        /* Header */
        .header { 
            display: flex; 
            justify-content: space-between; 
            align-items: center;
            margin-bottom: 40px;
            flex-wrap: wrap;
            gap: 20px;
        }
        .header-left h1 {
            font-size: 2rem;
            font-weight: 700;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            margin-bottom: 4px;
        }
        .header-left p { color: #888; font-size: 0.9rem; }
        
        /* Status Bar */
        .status-bar {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 12px 20px;
            background: #1a1d27;
            border: 1px solid #2a2d3a;
            border-radius: 12px;
            margin-bottom: 30px;
        }
        .status-dot {
            width: 10px;
            height: 10px;
            border-radius: 50%;
            background: #4caf50;
            animation: pulse 2s infinite;
        }
        .status-dot.offline { background: #f44336; animation: none; }
        .status-dot.warning { background: #ff9800; animation: pulse-warning 2s infinite; }
        .status-text { font-size: 0.9rem; color: #aaa; }
        .last-update { margin-left: auto; font-size: 0.8rem; color: #666; }
        
        /* Cards Grid */
        .cards-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
            gap: 20px;
            margin-bottom: 30px;
        }
        .card {
            background: #1a1d27;
            border: 1px solid #2a2d3a;
            border-radius: 16px;
            padding: 24px;
            transition: all 0.2s ease;
            position: relative;
            overflow: hidden;
        }
        .card:hover {
            border-color: #667eea;
            transform: translateY(-2px);
            box-shadow: 0 8px 30px rgba(102, 126, 234, 0.12);
        }
        .card::before {
            content: '';
            position: absolute;
            top: 0; left: 0; right: 0;
            height: 3px;
            background: linear-gradient(90deg, #667eea, #764ba2);
        }
        .card-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 20px;
        }
        .card-title {
            font-size: 1.1rem;
            font-weight: 600;
            color: #fff;
            display: flex;
            align-items: center;
            gap: 10px;
        }
        .card-icon { font-size: 1.4rem; }
        
        /* Metrics */
        .metrics-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 16px;
        }
        .metric-box {
            background: #252836;
            border-radius: 12px;
            padding: 16px;
            text-align: center;
        }
        .metric-value {
            font-size: 1.8rem;
            font-weight: 700;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }
        .metric-label {
            font-size: 0.75rem;
            color: #666;
            margin-top: 6px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }
        
        /* Newsletter Types */
        .newsletter-list {
            display: flex;
            flex-direction: column;
            gap: 12px;
        }
        .newsletter-item {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 14px;
            background: #252836;
            border-radius: 10px;
            border-left: 4px solid #667eea;
        }
        .newsletter-info h4 {
            font-size: 0.9rem;
            font-weight: 600;
            color: #fff;
            margin-bottom: 4px;
        }
        .newsletter-info p {
            font-size: 0.8rem;
            color: #888;
        }
        .newsletter-status {
            display: flex;
            align-items: center;
            gap: 8px;
        }
        
        /* Cron Status */
        .cron-status {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 16px;
            background: #252836;
            border-radius: 12px;
            margin-top: 16px;
        }
        .cron-info h4 {
            font-size: 0.9rem;
            font-weight: 600;
            color: #fff;
            margin-bottom: 4px;
        }
        .cron-info p {
            font-size: 0.8rem;
            color: #888;
        }
        
        /* Account Status */
        .account-status {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 16px;
            background: #252836;
            border-radius: 12px;
            margin-top: 16px;
        }
        
        /* Animations */
        @keyframes pulse {
            0% { opacity: 1; }
            50% { opacity: 0.5; }
            100% { opacity: 1; }
        }
        @keyframes pulse-warning {
            0% { opacity: 1; }
            50% { opacity: 0.3; }
            100% { opacity: 1; }
        }
        
        /* Responsive */
        @media (max-width: 768px) {
            .cards-grid { grid-template-columns: 1fr; }
            .metrics-grid { grid-template-columns: 1fr; }
            .header { flex-direction: column; align-items: flex-start; }
            .status-bar { flex-direction: column; align-items: flex-start; gap: 8px; }
            .last-update { margin-left: 0; }
        }
    </style>
</head>
<body>
    <div class="container">
        <!-- Header -->
        <div class="header">
            <div class="header-left">
                <h1>📰 Newsletter Operations Hub</h1>
                <p>Real-time monitoring & management for AI newsletter pipeline</p>
            </div>
        </div>
        
        <!-- Status Bar -->
        <div class="status-bar">
            <div class="status-dot" id="systemStatusDot"></div>
            <span class="status-text" id="systemStatusText">System Status: Loading...</span>
            <span class="last-update" id="lastUpdate">Last updated: Loading...</span>
        </div>
        
        <!-- Main Cards Grid -->
        <div class="cards-grid">
            <!-- System Overview Card -->
            <div class="card">
                <div class="card-header">
                    <h2 class="card-title"><span class="card-icon">📊</span> System Overview</h2>
                </div>
                <div class="metrics-grid">
                    <div class="metric-box">
                        <div class="metric-value" id="uptimeValue">0d</div>
                        <div class="metric-label">Uptime</div>
                    </div>
                    <div class="metric-box">
                        <div class="metric-value" id="articlesScraped">0</div>
                        <div class="metric-label">Articles Scraped</div>
                    </div>
                    <div class="metric-box">
                        <div class="metric-value" id="successRate">0%</div>
                        <div class="metric-label">Success Rate</div>
                    </div>
                    <div class="metric-box">
                        <div class="metric-value" id="totalSent">0</div>
                        <div class="metric-label">Emails Sent</div>
                    </div>
                </div>
            </div>
            
            <!-- Next Send & Cron Status Card -->
            <div class="card">
                <div class="card-header">
                    <h2 class="card-title"><span class="card-icon">⏰</span> Schedule & Cron</h2>
                </div>
                
                <div class="cron-status">
                    <div class="status-dot" id="cronStatusDot"></div>
                    <div class="cron-info">
                        <h4 id="nextSendTitle">Next Newsletter Send</h4>
                        <p id="nextSendTime">Loading cron status...</p>
                    </div>
                </div>
                
                <div class="cron-status">
                    <div class="status-dot" id="lastSendStatusDot"></div>
                    <div class="cron-info">
                        <h4>Last Send Status</h4>
                        <p id="lastSendStatus">Loading last send data...</p>
                    </div>
                </div>
            </div>
            
            <!-- Newsletter Types Card -->
            <div class="card">
                <div class="card-header">
                    <h2 class="card-title"><span class="card-icon">📰</span> Newsletter Types</h2>
                </div>
                
                <div class="newsletter-list">
                    <div class="newsletter-item">
                        <div class="newsletter-info">
                            <h4>Daily AI Tech News</h4>
                            <p id="dailyAiStatus">Last: Never, Articles: 0</p>
                        </div>
                        <div class="newsletter-status">
                            <div class="status-dot" id="dailyAiDot"></div>
                            <span style="font-size: 0.8rem; color: #888;">Status</span>
                        </div>
                    </div>
                    
                    <div class="newsletter-item">
                        <div class="newsletter-info">
                            <h4>AI Management Bulletin</h4>
                            <p id="managementStatus">Last: Never, Articles: 0</p>
                        </div>
                        <div class="newsletter-status">
                            <div class="status-dot" id="managementDot"></div>
                            <span style="font-size: 0.8rem; color: #888;">Status</span>
                        </div>
                    </div>
                    
                    <div class="newsletter-item">
                        <div class="newsletter-info">
                            <h4>AI Security Update</h4>
                            <p id="securityStatus">Last: Never, Articles: 0</p>
                        </div>
                        <div class="newsletter-status">
                            <div class="status-dot" id="securityDot"></div>
                            <span style="font-size: 0.8rem; color: #888;">Status</span>
                        </div>
                    </div>
                </div>
            </div>
            
            <!-- Account & Subscribers Card -->
            <div class="card">
                <div class="card-header">
                    <h2 class="card-title"><span class="card-icon">👥</span> Account & Subscribers</h2>
                </div>
                
                <div class="metrics-grid">
                    <div class="metric-box">
                        <div class="metric-value" id="subscriberCount">0</div>
                        <div class="metric-label">Subscribers</div>
                    </div>
                    <div class="metric-box">
                        <div class="metric-value" id="deliveryRate">0%</div>
                        <div class="metric-label">Delivery Rate</div>
                    </div>
                </div>
                
                <div class="account-status">
                    <div class="status-dot" id="accountStatusDot"></div>
                    <div class="cron-info">
                        <h4>Gmail/OAuth Account Status</h4>
                        <p id="accountStatusText">Checking account status...</p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script>
        // API endpoints (to be configured based on actual backend)
        const API_ENDPOINTS = {
            systemStatus: '/api/newsletter/system-status',
            cronStatus: '/api/newsletter/cron-status',
            newsletterStats: '/api/newsletter/stats',
            accountStatus: '/api/newsletter/account-status'
        };
        
        // Mock data for initial display (will be replaced with real API calls)
        const mockData = {
            systemStatus: 'healthy',
            uptime: '5 months',
            articlesScraped: 463,
            successRate: '98.5%',
            totalSent: 47,
            nextSend: '2026-04-22 07:30:00',
            lastSend: { time: '2026-04-21 07:30:00', status: 'success' },
            newsletterTypes: {
                dailyAi: { last: '2026-04-21 07:30:00', articles: 14, status: 'healthy' },
                management: { last: '2026-04-20 09:00:00', articles: 18, status: 'healthy' },
                security: { last: '2026-04-17 09:00:00', articles: 12, status: 'healthy' }
            },
            subscribers: 1,
            deliveryRate: '100%',
            accountStatus: 'active',
            lastUpdate: new Date().toISOString()
        };
        
        // Status mapping
        const statusConfig = {
            healthy: { color: '#4caf50', text: 'HEALTHY', dotClass: '' },
            degraded: { color: '#ff9800', text: 'DEGRADED', dotClass: 'warning' },
            error: { color: '#f44336', text: 'ERROR', dotClass: 'offline' },
            pending: { color: '#9e9e9e', text: 'PENDING', dotClass: 'offline' }
        };
        
        // Helper functions
        function formatDate(dateString) {
            if (!dateString || dateString === 'Never') return 'Never';
            try {
                const date = new Date(dateString);
                return date.toLocaleDateString('en-US', { 
                    month: 'short', 
                    day: 'numeric',
                    hour: '2-digit',
                    minute: '2-digit'
                });
            } catch (e) {
                return dateString;
            }
        }
        
        function updateNewsletterStatus(type, data) {
            const elementId = type === 'dailyAi' ? 'dailyAi' : 
                             type === 'management' ? 'management' : 'security';
            
            document.getElementById(`${elementId}Status`).textContent = 
                `Last: ${data.last}, Articles: ${data.articles}`;
            
            const status = statusConfig[data.status] || statusConfig.pending;
            document.getElementById(`${elementId}Dot`).className = `status-dot ${status.dotClass}`;
        }
        
        function updateLastUpdate() {
            const now = new Date();
            const formatted = now.toLocaleString('en-US', {
                month: 'short',
                day: 'numeric',
                hour: '2-digit',
                minute: '2-digit',
                second: '2-digit'
            });
            document.getElementById('lastUpdate').textContent = `Last updated: ${formatted}`;
        }
        
        // Update UI with data
        function updateUIWithData(data) {
            // System status
            const systemStatus = statusConfig[data.systemStatus] || statusConfig.pending;
            document.getElementById('systemStatusDot').className = `status-dot ${systemStatus.dotClass}`;
            document.getElementById('systemStatusText').textContent = `System Status: ${systemStatus.text}`;
            
            // Metrics
            document.getElementById('uptimeValue').textContent = data.uptime;
            document.getElementById('articlesScraped').textContent = data.articlesScraped;
            document.getElementById('successRate').textContent = data.successRate;
            document.getElementById('totalSent').textContent = data.totalSent;
            
            // Cron status
            const cronStatus = data.lastSend.status === 'success' ? 'healthy' : 
                              data.lastSend.status === 'failed' ? 'error' : 'pending';
            const cronStatusConfig = statusConfig[cronStatus];
            document.getElementById('cronStatusDot').className = `status-dot ${cronStatusConfig.dotClass}`;
            document.getElementById('nextSendTitle').textContent = `Next Send: ${formatDate(data.nextSend)}`;
            document.getElementById('nextSendTime').textContent = `Scheduled: ${data.nextSend}`;
            
            // Last send status
            const lastSendStatus = data.lastSend.status === 'success' ? 'healthy' : 
                                  data.lastSend.status === 'failed' ? 'error' : 'pending';
            const lastSendConfig = statusConfig[lastSendStatus];
            document.getElementById('lastSendStatusDot').className = `status-dot ${lastSendConfig.dotClass}`;
            document.getElementById('lastSendStatus').textContent = `${data.lastSend.time} - ${lastSendConfig.text}`;
            
            // Newsletter types
            updateNewsletterStatus('dailyAi', data.newsletterTypes.dailyAi);
            updateNewsletterStatus('management', data.newsletterTypes.management);
            updateNewsletterStatus('security', data.newsletterTypes.security);
            
            // Subscribers and account
            document.getElementById('subscriberCount').textContent = data.subscribers;
            document.getElementById('deliveryRate').textContent = data.deliveryRate;
        }
        
        // Initialize dashboard with data
        updateUIWithData(mockData);
        updateLastUpdate();
        
        // Auto-refresh every 5 minutes
        setInterval(() => {
            updateLastUpdate();
        }, 300000);
    </script>
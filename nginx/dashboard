server {
    listen 80;
    server_name dashboard.claw.lkohl.duckdns.org;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name dashboard.claw.lkohl.duckdns.org;

    ssl_certificate /etc/letsencrypt/live/claw.lkohl.duckdns.org/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/claw.lkohl.duckdns.org/privkey.pem;
    ssl_protocols TLSv1.2 TLSv1.3;

    root /var/www/dashboard;
    index index.html;

    location / {
        try_files $uri $uri/ =404;
    }

    location /newsletter/ {
        alias /var/www/newsletter-dashboard/;
        index index.html status.html;
        try_files $uri $uri/ =404;
    }

    location /healthhub/ {
        proxy_pass http://localhost:3000/healthhub/;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    }

    location /bodycomp/ {
        proxy_pass http://localhost:8501/bodycomp/;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
    }

    location /arca/ {
        proxy_pass http://localhost:5173/;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_redirect off;
    }

    location ~* \.(html)$ {
        expires 5m;
        add_header Cache-Control "public, must-revalidate";
    }

    location ~ /\. {
        deny all;
    }

    add_header X-Frame-Options "SAMEORIGIN" always;
    add_header X-Content-Type-Options "nosniff" always;
}
